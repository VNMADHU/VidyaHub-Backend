DATABASE_URL=postgresql://postgres@localhost:5432/vidya_hub_dev
NODE_ENV=development
PORT=5000
JWT_SECRET=replace-with-strong-secret-in-production-key-must-be-32-chars-or-more
CORS_ORIGIN=http://localhost:5173

# ── SMS Provider ──────────────────────────────────────────
# Options: twilio | msg91 | saptele | bulksmsgateway | (empty = dev/log only)
SMS_PROVIDER=

# ── BulkSMSGateway (WhatsApp + SMS) ──────────────────────
# Used when SMS_PROVIDER=bulksmsgateway  →  type=2 (regular SMS)
# Used always for WhatsApp channel       →  type=3 (WhatsApp message)
# Domain: login.bulksmsgateway.in
BULKSMS_USER=VNMADHU
BULKSMS_PASSWORD=your-password-here
# ── Saptele (GreenAds Global) ─────────────────────────────
# Set SMS_PROVIDER=saptele and fill these in
SAPTELE_API_KEY=
SAPTELE_SENDER_NAME=VIDYAH
SAPTELE_BASE_URL=https://sapteleservices.com/SMS_API/sendsms.php

# DLT-registered Template IDs — one per message type
# (register each template on your telecom operator's DLT portal first)
SAPTELE_TRANSACTIONAL_TEMPLATE_ID=   # OTP / fallback

# Auto-used for absence alerts (attendanceController)
# Template: "Dear Parent, your child {#var#} was marked absent on {#var#}. - {#var#}"
SAPTELE_ABSENT_TEMPLATE_ID=1707170000000000047

# Auto-used for fee assignment & payment receipts (feeController)
# Template: "Dear Parent, a fee of Rs.{#var#} ({#var#}) has been assigned for {#var#}. Due date: {#var#}. - {#var#}"
SAPTELE_FEE_TEMPLATE_ID=1707170000000000037

# Auto-used for leave approval/rejection (leaveController)
# Template: "Dear {#var#}, your leave application from {#var#} to {#var#} has been {#var#}. - {#var#}"
SAPTELE_LEAVE_TEMPLATE_ID=1707170000000000027

# Auto-used for announcements broadcast (announcementController)
# Template: "{#var#} Announcement: {#var#} - {#var#}"
SAPTELE_ANNOUNCEMENT_TEMPLATE_ID=1707170000000000017

# ── Twilio (alternative provider) ────────────────────────
# Set SMS_PROVIDER=twilio and fill these in
# npm install twilio
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=