SMTP_PORT=587
SMTP_SECURE=false
IAMUSERNAME=AKIA2SXG3CTA77FJDV6H
SMTP_USER=AKIA2SXG3CTA77FJDV6H
SMTP_PASS=BMeYOrqA9hGEXV3qT7LjUeOOgNhsLVvtQ3a/jP2gYnBv
SMTP_FROM=Vidya Hub <venkatan847@gmail.com>
# ── BulkSMSGateway (WhatsApp + SMS) ──────────────────────
# Used when SMS_PROVIDER=bulksmsgateway  →  type=2 (regular SMS)
# Used always for WhatsApp channel       →  type=3 (WhatsApp message)
# Domain: login.bulksmsgateway.in
BULKSMS_USER=VNMADHU
BULKSMS_PASSWORD=your-password-here
# ── Saptele (GreenAds Global) ─────────────────────────────
# Set SMS_PROVIDER=saptele and fill these in
SAPTELE_API_KEY=
SAPTELE_SENDER_NAME=VIDYAH
SAPTELE_BASE_URL=https://sapteleservices.com/SMS_API/sendsms.php

# ════════════════════════════════════════════════════════════
# DLT-REGISTERED SMS TEMPLATES  (Saptele / GreenAds Global)
# Register each template on your telecom DLT portal, then paste
# the approved Template ID into the corresponding variable below.
# ════════════════════════════════════════════════════════════

# ── TEMPLATE 1 · OTP / Verification ─────────────────────────
# Used for: login MFA, phone verification, password reset
# DLT Template Text (register exactly as shown, {#var#} = variable):
#   Dear VidyaHub user, {#var#} is your verification code for VidyaHub.
#   Please contact us for assistance.
# Variables: 1  (OTP code)
# Type: Transactional
SAPTELE_TRANSACTIONAL_TEMPLATE_ID=1707170000000000034
# After DLT approval, paste the exact approved text here
# (must keep {code} as the placeholder — the app replaces it at runtime)
SAPTELE_OTP_TEMPLATE=Dear VidyaHub user, {code} is your verification code for VidyaHub. Please contact us for assistance.

# ── TEMPLATE 2 · Absent Alert ────────────────────────────────
# Used for: attendance controller — marks a student absent
# DLT Template Text:
#   Dear Parent, your child {#var#} {#var#} was marked absent on {#var#}. - {#var#}
# Variables: 4  (First Name, Last Name, Date YYYY-MM-DD, School Name)
# Type: Transactional
SAPTELE_ABSENT_TEMPLATE_ID=1707170000000000043

# ── TEMPLATE 3 · Fee Assignment ──────────────────────────────
# Used for: fee controller — when a fee record is created
# DLT Template Text:
#   Dear Parent, a fee of Rs.{#var#} ({#var#}) has been assigned for {#var#} {#var#}. Due date: {#var#}. - {#var#}
# Variables: 6  (Amount, Fee Type, First Name, Last Name, Due Date, School Name)
# Type: Transactional
SAPTELE_FEE_TEMPLATE_ID=1707170000000000052

# ── TEMPLATE 4 · Fee Payment Receipt ────────────────────────
# Used for: fee controller — when a payment is recorded (payFee)
# DLT Template Text:
#   Dear Parent, payment of Rs.{#var#} received for {#var#} {#var#} ({#var#} fee). Status: {#var#}. Paid Date: {#var#}. - {#var#}
# Variables: 7  (Amount, First Name, Last Name, Fee Type, Status, Paid Date, School Name)
# Type: Transactional
SAPTELE_FEE_PAYMENT_TEMPLATE_ID=1707170000000000061

# ── TEMPLATE 5 · Leave Status ────────────────────────────────
# Used for: leave controller — when leave is approved or rejected
# DLT Template Text:
#   Dear {#var#}, your leave application from {#var#} to {#var#} has been {#var#}. - {#var#}
# Variables: 5  (Employee Name, From Date, To Date, Status approved/rejected, School Name)
# Type: Transactional
SAPTELE_LEAVE_TEMPLATE_ID=1707170000000000070

# ── TEMPLATE 6 · Announcement ───────────────────────────────
# Used for: announcement controller — school-wide broadcasts
# DLT Template Text:
#   {#var#} Announcement: {#var#} - {#var#}
# Variables: 3  (School Name, Title, Message body)
# Type: Transactional
SAPTELE_ANNOUNCEMENT_TEMPLATE_ID=1707170000000000080

# ── Twilio (alternative provider) ────────────────────────
# Set SMS_PROVIDER=twilio and fill these in
# npm install twilio
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=