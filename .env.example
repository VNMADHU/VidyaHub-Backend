DATABASE_URL=postgresql://postgres@localhost:5432/vidya_hub_dev
NODE_ENV=development
PORT=5000
JWT_SECRET=replace-with-strong-secret-in-production-key-must-be-32-chars-or-more
CORS_ORIGIN=http://localhost:5173

# ── SMS Provider ──────────────────────────────────────────
# Options: twilio | msg91 | saptele | bulksmsgateway | (empty = dev/log only)
SMS_PROVIDER=

# ── BulkSMSGateway (WhatsApp + SMS) ──────────────────────
# Used when SMS_PROVIDER=bulksmsgateway  →  type=2 (regular SMS)
# Used always for WhatsApp channel       →  type=3 (WhatsApp message)
# Domain: login.bulksmsgateway.in
BULKSMS_USER=VNMADHU
BULKSMS_PASSWORD=your-password-here
